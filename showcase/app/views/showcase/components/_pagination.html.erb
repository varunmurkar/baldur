<% content_for :title, "Pagination — Components — Baldur Showcase" %>

<header class="showcase-page-header">
  <h1 class="showcase-page-header__title">Pagination</h1>
  <p class="showcase-page-header__lede">Page controls, gap markers and rows-per-page selector for tabular data.</p>
</header>

<% simple_source = <<~ERB.strip
  ui_pagination(
    current_page: 3,
    total_pages: 10,
    total_count: 96,
    per_page: 10,
    path_builder: ->(p) { "#page=#{p}" }
  )
ERB

simple_content = capture do
  concat ui_pagination(
    current_page: 3,
    total_pages: 10,
    total_count: 96,
    per_page: 10,
    path_builder: ->(p) { "#page=#{p}" }
  )
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "Simple pagination", source: simple_source } do %>
  <%= simple_content %>
<% end %>

<% with_rows_source = <<~ERB.strip
  ui_pagination(
    current_page: 1,
    total_pages: 5,
    total_count: 48,
    per_page: 10,
    rows_per_page_options: [10, 25, 50],
    rows_per_page_selected: 10,
    rows_per_page_param: 'per_page',
    path_builder: ->(p) { "#page=#{p}" }
  )
ERB

with_rows_content = capture do
  concat ui_pagination(
    current_page: 1,
    total_pages: 5,
    total_count: 48,
    per_page: 10,
    rows_per_page_options: [10, 25, 50],
    rows_per_page_selected: 10,
    rows_per_page_param: "per_page",
    path_builder: ->(p) { "#page=#{p}" }
  )
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "With rows per page", source: with_rows_source } do %>
  <%= with_rows_content %>
<% end %>
