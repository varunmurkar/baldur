<% content_for :title, "Segmented buttons — Components — Baldur Showcase" %>

<header class="showcase-page-header">
  <h1 class="showcase-page-header__title">Segmented buttons</h1>
  <p class="showcase-page-header__lede">Compact tab-like control for switching between a small set of related options.</p>
</header>

<% text_source = <<~ERB.strip
  ui_segmented_buttons(
    aria_label: 'Billing period',
    items: [
      { label: 'Monthly', value: 'monthly' },
      { label: 'Yearly', value: 'yearly', selected: true }
    ]
  )
ERB

text_content = capture do
  concat ui_segmented_buttons(
    aria_label: "Billing period",
    items: [
      { label: "Monthly", value: "monthly" },
      { label: "Yearly", value: "yearly", selected: true }
    ]
  )
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "Text segments", source: text_source } do %>
  <%= text_content %>
<% end %>

<% icon_source = <<~ERB.strip
  ui_segmented_buttons(
    aria_label: 'View layout',
    items: [
      { label: 'List', value: 'list', icon: 'list', selected: true },
      { label: 'Grid', value: 'grid', icon: 'layout-grid' },
      { label: 'Map', value: 'map', icon: 'map', disabled: true }
    ]
  )
ERB

icon_content = capture do
  concat ui_segmented_buttons(
    aria_label: "View layout",
    items: [
      { label: "List", value: "list", icon: "list", selected: true },
      { label: "Grid", value: "grid", icon: "layout-grid" },
      { label: "Map", value: "map", icon: "map", disabled: true }
    ]
  )
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "Icon segments", source: icon_source } do %>
  <%= icon_content %>
<% end %>
