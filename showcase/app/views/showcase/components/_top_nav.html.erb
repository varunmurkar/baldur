<% content_for :title, "Top nav — Components — Baldur Showcase" %>

<header class="showcase-page-header">
  <h1 class="showcase-page-header__title">Top nav</h1>
  <p class="showcase-page-header__lede">Marketing site header with brand, links and a primary call-to-action.</p>
</header>

<% nav_source = <<~ERB.strip
  ui_marketing_top_nav(
    brand: { name: 'Baldur' },
    links: [
      { label: 'Product', href: '#' },
      { label: 'Pricing', href: '#' },
      { label: 'Docs', href: '#' }
    ],
    primary_action: { label: 'Get started', href: '#' }
  )
ERB

nav_content = capture do
  concat ui_marketing_top_nav(
    brand: { name: "Baldur" },
    links: [
      { label: "Product", href: "#" },
      { label: "Pricing", href: "#" },
      { label: "Docs", href: "#" }
    ],
    primary_action: { label: "Get started", href: "#" }
  )
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "Marketing top nav", source: nav_source } do %>
  <%= nav_content %>
<% end %>

<% themed_source = <<~ERB.strip
  ui_marketing_top_nav(
    brand: { name: 'Baldur' },
    links: [
      { label: 'Features', href: '#' },
      { label: 'Use cases', href: '#' }
    ],
    primary_action: { label: 'Sign up', href: '#' },
    theme_toggle: ui_theme_toggle
  )
ERB

themed_content = capture do
  concat ui_marketing_top_nav(
    brand: { name: "Baldur" },
    links: [
      { label: "Features", href: "#" },
      { label: "Use cases", href: "#" }
    ],
    primary_action: { label: "Sign up", href: "#" },
    theme_toggle: ui_theme_toggle
  )
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "With theme toggle", source: themed_source } do %>
  <%= themed_content %>
<% end %>
