<% content_for :title, "Date field — Components — Baldur Showcase" %>

<header class="showcase-page-header">
  <h1 class="showcase-page-header__title">Date field</h1>
  <p class="showcase-page-header__lede">Text input with an attached native date picker and min/max date bounds.</p>
</header>

<% basic_source = <<~ERB.strip
  ui_date_field_tag('event[starts_on]', nil, label: 'Start date', supporting_text: 'Pick a date from the calendar.')
ERB

basic_content = capture do
  concat ui_date_field_tag("event[starts_on]", nil, label: "Start date", supporting_text: "Pick a date from the calendar.")
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "Basic date field", source: basic_source } do %>
  <%= basic_content %>
<% end %>

<% bounded_source = <<~ERB.strip
  ui_date_field_tag(
    'booking[date]',
    Date.today,
    label: 'Booking date',
    min_date: Date.today,
    max_date: 30.days.from_now.to_date,
    supporting_text: 'You can book up to 30 days in advance.'
  )
ERB

bounded_content = capture do
  concat ui_date_field_tag(
    "booking[date]",
    Date.today,
    label: "Booking date",
    min_date: Date.today,
    max_date: 30.days.from_now.to_date,
    supporting_text: "You can book up to 30 days in advance."
  )
end %>

<%= render layout: "showcase/shared/example_card", locals: { title: "Bounded date range", source: bounded_source } do %>
  <%= bounded_content %>
<% end %>
