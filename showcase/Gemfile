source "https://rubygems.org"

git_source(:github) { |repo| "https://github.com/#{repo}.git" }

# Load Baldur from the parent directory so showcase always tracks local gem changes.
gem "baldur", path: ".."

# Pinned to same versions declared by Baldur's supported stack.
gem "rails", "~> 8.1.3"
gem "propshaft"
gem "puma", ">= 5.0"
gem "tailwindcss-rails"

# JavaScript asset mapping and Stimulus required by Baldur controllers.
gem "importmap-rails"
gem "stimulus-rails"
gem "turbo-rails"

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
gem "tzinfo-data", platforms: %i[ windows jruby ]

group :development, :test do
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"
end

group :test do
  gem "minitest"
end
